DATABASE_URL=postgresql://postgres:password@localhost:5432/trellis_test
# For Cloud Run, prefer DB_* plus DB_CONNECTION_NAME instead of DATABASE_URL.
# DB_NAME=trellis
# DB_USER=postgres
# DB_PASSWORD=<DB_PASSWORD>
# DB_CONNECTION_NAME=<PROJECT_ID>:us-central1:trellis-db
GCP_PROJECT_ID=<PROJECT_ID>
GCP_REGION=us-central1
APP_ENV=development
# Prefer gcloud application-default credentials locally.
# GOOGLE_APPLICATION_CREDENTIALS=<ABSOLUTE_PATH_TO_SA_KEY_JSON>
API_BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:5173

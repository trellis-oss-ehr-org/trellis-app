VITE_FIREBASE_API_KEY=<FIREBASE_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<PROJECT_ID>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<PROJECT_ID>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<FIREBASE_MESSAGING_SENDER_ID>
VITE_FIREBASE_APP_ID=<FIREBASE_APP_ID>
VITE_FIREBASE_VAPID_KEY=<FIREBASE_VAPID_KEY>
# Optional in local dev because Vite proxies /api and /ws.
# Set these only when pointing the frontend at deployed services.
# VITE_API_URL=<CLOUD_RUN_API_URL>
# VITE_WS_URL=<CLOUD_RUN_RELAY_URL>
